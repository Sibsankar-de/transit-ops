enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Vehicle {
  id                 String        @id @default(uuid())
  registrationNumber String        @unique
  name               String
  type               String        // Truck, Van, Bus, etc. — filterable
  maxLoadCapacity    Decimal       // kg
  odometer           Decimal
  acquisitionCost    Decimal
  region             String
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips           Trip[]
  maintenanceLogs MaintenanceLog[]
  fuelLogs        FuelLog[]
  expenses        Expense[]
}
