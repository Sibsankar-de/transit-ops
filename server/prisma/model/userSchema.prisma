enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  refreshToken String?
  status       UserStatus @default(ACTIVE)
  roleId       String?
  role         Role?      @relation(fields: [roleId], references: [id])
  driver       Driver?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}
