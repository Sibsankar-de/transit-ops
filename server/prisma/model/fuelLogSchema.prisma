model FuelLog {
  id        String   @id @default(uuid())
  vehicleId String
  tripId    String?
  liters    Decimal
  cost      Decimal
  date      DateTime
  createdAt DateTime @default(now())

  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  trip      Trip?    @relation(fields: [tripId], references: [id])
}
